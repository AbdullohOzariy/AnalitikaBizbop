DATABASE_URL="postgresql://user:password@localhost:5432/analitika?schema=public"

# NextAuth (Auth.js v5)
# Production uchun yangi tasodifiy qiymat: openssl rand -base64 32
AUTH_SECRET="change-me-please-32-chars-minimum-required"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Birinchi seed admin (faqat dev uchun)
SEED_ADMIN_EMAIL="admin@analitika.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"

# ─── Hisobdan chiqarish / Telegram bot (bizbop bazasi) ────────────────────────
# Bot endi alohida servis emas — shu Next ilova ichida ishlaydi (webhook rejimi).

# bizbop Postgres (yozuvlar/vozvrat/filialar/kategoriyalar). Bosh bolsa bolim ochadi.
BOT_DATABASE_URL=postgresql://user:pass@host:5432/bizbop

# Telegram bot tokeni (@BotFather). Bosh bolsa bot/miniapp ochadi.
BOT_TOKEN=000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ilova manzili — webhook shu manzilga ornatiladi, miniapp shu yerdan ochiladi.
WEBHOOK_URL=https://analitika.oilagroup.uz

# /panel buyrugi uchun admin Telegram ID lari (vergul bilan).
ADMIN_IDS=123456789,987654321

# Telegram guruh chat_id (yangi yozuv xabarlari). Bosh bolsa bizbop sozlamalaridan oqiladi.
GROUP_CHAT_ID=-100xxxxxxxxxx

# AI mahsulot kategoriyalash (Claude Haiku). Bosh bolsa kategoriyalash ochadi.
ANTHROPIC_API_KEY=sk-ant-...
