DATABASE_URL="postgresql://user:password@localhost:5432/analitika?schema=public"
# Migratsiya/to'g'ridan-to'g'ri ulanish (Neon pooler'siz). Bo'sh bo'lsa DATABASE_URL'dan -pooler olib tashlanadi.
DIRECT_URL="postgresql://user:password@localhost:5432/analitika?schema=public"

# NextAuth (Auth.js v5)
# Production uchun yangi tasodifiy qiymat: openssl rand -base64 32
AUTH_SECRET="change-me-please-32-chars-minimum-required"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Birinchi seed admin (faqat dev uchun)
SEED_ADMIN_EMAIL="admin@analitika.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"

# ─── Hisobdan chiqarish / Telegram bot (bizbop bazasi) ────────────────────────
# Bot endi alohida servis emas — shu Next ilova ichida ishlaydi (webhook rejimi).

# bizbop Postgres (yozuvlar/vozvrat/filialar/kategoriyalar). Bosh bolsa bolim ochadi.
BOT_DATABASE_URL=postgresql://user:pass@host:5432/bizbop

# Telegram bot tokeni (@BotFather). Bosh bolsa bot/miniapp ochadi.
BOT_TOKEN=000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ilova manzili — webhook shu manzilga ornatiladi, miniapp shu yerdan ochiladi.
WEBHOOK_URL=https://analitika.oilagroup.uz

# /panel buyrugi uchun admin Telegram ID lari (vergul bilan).
ADMIN_IDS=123456789,987654321

# Telegram guruh chat_id (yangi yozuv xabarlari). Bosh bolsa bizbop sozlamalaridan oqiladi.
GROUP_CHAT_ID=-100xxxxxxxxxx

# AI mahsulot kategoriyalash (DeepSeek). Bosh bolsa AI kategoriyalash ochadi.
# (src/lib/ai-matcher.ts shu kalitni o'qiydi.)
DEEPSEEK_API_KEY=sk-...

# ─── AI: sotuv prognozi + spisaniya kategoriyalash (Anthropic) ────────────────
# Bo'sh bo'lsa AI prognoz (src/lib/forecast.ts) va AI kategoriyalash
# (src/lib/spisaniya/kategoriya.ts) JIMGINA o'chadi — funksiya ishlamaydi, xato bermaydi.
ANTHROPIC_API_KEY=sk-ant-...
# Prognoz modeli (ixtiyoriy; default: forecast.ts ichidagi qiymat).
FORECAST_MODEL=claude-sonnet-4-6

# ─── Ma'lumot saqlash siyosati ────────────────────────────────────────────────
# ProductSales necha oy saqlanadi (undan eskisi upload'da o'chiriladi). Default: 24.
PRODUCTSALES_RETENTION_MONTHS=24

# Destruktiv seed/skriptlarga ruxsat (prisma/seed-sku.ts, scripts/test-upload-flow.ts).
# Lokal bo'lmagan DB'da bu skriptlar faqat "1" bo'lsa ishlaydi (aks holda to'xtaydi).
ALLOW_DESTRUCTIVE_SEED=0

# ─── Sverka (mini app) Telegram guruhi ────────────────────────────────────────
SVERKA_GROUP_CHAT_ID=-100xxxxxxxxxx

# ─── Kunlik hisobot cron'lari — Telegram yo'nalishi (env = OVERRIDE) ───────────
# Har uchlik (TOKEN + GROUP_CHAT_ID + TOPIC_ID) ixtiyoriy: env bo'lmasa qiymat
# DB'dagi Sozlama jadvalidan (admin UI) o'qiladi. Ya'ni bularsiz ham ishlaydi,
# lekin admin sozlamalari bo'sh bo'lsa hisobot yuborilmaydi.
# TOPIC_ID — guruh mavzusi (forum topic); oddiy guruhda bo'sh qoldiring.
INVENTORY_BOT_TOKEN=
INVENTORY_GROUP_CHAT_ID=
INVENTORY_TOPIC_ID=
MARGIN_BOT_TOKEN=
MARGIN_GROUP_CHAT_ID=
MARGIN_TOPIC_ID=
DELIVERY_BOT_TOKEN=
DELIVERY_GROUP_CHAT_ID=
DELIVERY_TOPIC_ID=
SPDAILY_BOT_TOKEN=
SPDAILY_GROUP_CHAT_ID=
SPDAILY_TOPIC_ID=
ZAKAZ_BOT_TOKEN=
ZAKAZ_GROUP_CHAT_ID=
ZAKAZ_TOPIC_ID=
