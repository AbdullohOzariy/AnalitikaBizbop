DATABASE_URL="postgresql://user:password@localhost:5432/analitika?schema=public"

# NextAuth (Auth.js v5)
# Production uchun yangi tasodifiy qiymat: openssl rand -base64 32
AUTH_SECRET="change-me-please-32-chars-minimum-required"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Birinchi seed admin (faqat dev uchun)
SEED_ADMIN_EMAIL="admin@analitika.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"

# Spisaniya-bot bazasiga READ-ONLY ulanish (bosh
# Spisaniya-bot DB (read-only). Bosh bolsa Hisobdan chiqarish bolimi ochadi.
BOT_DATABASE_URL=postgresql://user:pass@host:5432/bizbop
