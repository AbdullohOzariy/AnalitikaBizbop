// Analitika BizBop — supermarket savdo analitika platformasi
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VIEWER // eskirgan — ishlatilmaydi (migratsiyada CAT_MANAGER'ga o'tkazilgan). UI'da yo'q.
  CAT_MANAGER
  CEO
}

// Zakaz (sotib olish buyurtmasi) holati
enum OrderStatus {
  DRAFT // Qoralama
  SENT // Yuborildi
  RECEIVED // Qabul qilindi
  RETURNED // Qaytarildi
}

enum FileType {
  SALES
  METRICS
  VISITS
  DAILY_PLANS
}

enum AliasSource {
  SALES
  VISITS
  SR
  PLANS
}

enum UploadStatus {
  SUCCESS
  FAILED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CAT_MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploads           UploadedFile[]
  managedCategories CategoryManager[] // kategoriya menejeri javobgar kategoriyalari
  purchaseOrders    PurchaseOrder[]
}

// Kategoriya menejeri ↔ kategoriya (ko'p-ko'p): bir xodim bir nechta kategoriyaga javobgar.
model CategoryManager {
  userId     Int
  categoryId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
}

model Branch {
  id        Int    @id @default(autoincrement())
  name      String @unique
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())

  aliases       BranchAlias[]
  sales         CategorySales[]
  productSales  ProductSales[]
  metrics       DailyMetrics[]
  visits        DailyVisits[]
  plans         MonthlyPlan[]
  dailyPlans    DailyPlan[]
  uploads       UploadedFile[]
}

model BranchAlias {
  id       Int         @id @default(autoincrement())
  branchId Int
  alias    String
  source   AliasSource

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([alias, source])
  @@index([branchId])
}

model CategoryGroup {
  id        Int    @id @default(autoincrement())
  name      String @unique
  code      Int?   @unique // 1C KOD — bo'lim identifikatori
  sortOrder Int    @default(0)

  categories Category[]
}

model Category {
  id        Int    @id @default(autoincrement())
  name      String // 1C'da bir xil nom turli joyda bo'lishi mumkin — farqlash code orqali
  code      Int?   @unique // 1C KOD — kategoriya/subkategoriya identifikatori va matching kaliti
  sortOrder Int    @default(0)
  groupId   Int?
  parentId  Int?

  group    CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parent   Category?      @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryParent")

  aliases    CategoryAlias[]
  sales      CategorySales[]
  products   Product[]
  plans      MonthlyPlan[]
  dailyPlans DailyPlan[]
  managers   CategoryManager[]

  @@index([parentId]) // scope filtrlari (subkat → ota-kategoriya) tezligi uchun
  @@index([groupId])
}

model CategoryAlias {
  id         Int    @id @default(autoincrement())
  categoryId Int
  alias      String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([alias])
  @@index([categoryId])
}

// Sotuv fayllaridan keladigan kategoriya bo'yicha summalar.
// Period 1 kun yoki bir necha kun bo'lishi mumkin (29.04 — bir kun, 1(2).xlsx — 29 kun).
model CategorySales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  categoryId     Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  amount         Decimal  @db.Decimal(20, 2)
  costAmount     Decimal? @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([categoryId, periodStart, periodEnd])
  @@index([uploadedFileId])
}

// sr.xlsx fayllaridan — kunlik chek metrikalari (filial majburiy).
model DailyMetrics {
  id                   Int      @id @default(autoincrement())
  uploadedFileId       Int
  branchId             Int
  date                 DateTime @db.Date
  receiptCount         Int
  receiptTotal         Decimal  @db.Decimal(20, 2)
  avgItemsPerReceipt   Decimal  @db.Decimal(10, 4)
  avgReceipt           Decimal  @db.Decimal(20, 2)
  bigPurchaseLevel     Decimal  @db.Decimal(20, 2)
  smallPurchaseLevel   Decimal  @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// export (1).xlsx — kunlik tashriflar (4 filialdan biri har qatorga).
model DailyVisits {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  date           DateTime @db.Date
  visitCount     Int

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// Admin qo'lda kiritadigan oylik "Normal Reja" — filial × oy × kategoriya × summa.
model MonthlyPlan {
  id         Int     @id @default(autoincrement())
  branchId   Int
  year       Int
  month      Int     // 1..12
  categoryId Int
  planAmount Decimal @db.Decimal(20, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, year, month, categoryId])
  @@index([year, month])
  @@index([branchId, year, month])
  @@index([categoryId, year, month])
}

// Kunlik reja — filial × sana × kategoriya × planAmount.
// "aprel 2026 kunlik planlar.xlsx" formatidagi fayllardan keladi.
model DailyPlan {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  categoryId     Int
  date           DateTime @db.Date
  planAmount     Decimal  @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([branchId, categoryId, date])
  @@index([uploadedFileId])
}

// Yuklangan har bir fayl audit + dublikat oldini olish uchun saqlanadi.
model UploadedFile {
  id           Int          @id @default(autoincrement())
  label        String       // admin tomonidan qo'yilgan nom (chalg'imaslik uchun)
  originalName String
  fileHash     String       @unique // sha256 — bir xil fayl 2 marta yuklanmaydi
  fileType     FileType
  branchId     Int?         // METRICS uchun majburiy, SALES bir filialli bo'lsa shunchaki
  periodStart  DateTime?    @db.Date
  periodEnd    DateTime?    @db.Date
  yearOverride Int?         // VISITS faylda yil bo'lmaganda admin tanlaydi
  templateVersion String?   // sotuv shabloni versiyasi (header signaturasidan: v1/v2/v3)
  rowCount     Int          @default(0)
  status       UploadStatus @default(SUCCESS)
  errorMessage String?
  uploadedById Int
  createdAt    DateTime     @default(now())

  uploadedBy User    @relation(fields: [uploadedById], references: [id])
  branch     Branch? @relation(fields: [branchId], references: [id])

  sales        CategorySales[]
  productSales ProductSales[]
  metrics      DailyMetrics[]
  visits       DailyVisits[]
  dailyPlans   DailyPlan[]

  @@index([fileType, periodStart, periodEnd])
  @@index([uploadedById])
}

// ─── Master baza: mahsulot (SKU) darajasidagi ma'lumot ───────────────────────
// Yangi sotuv shabloni (ShablonSotuv.xlsx) mahsulot darajasida keladi.
// Product = 1C mahsulot katalogi; ProductSales = SKU × filial × davr fakt jadval.

model Product {
  id         Int      @id @default(autoincrement())
  code       Int      @unique // 1C mahsulot kodi
  name       String
  categoryId Int? // tegishli kategoriya/subkategoriya (iyerarxiyadagi joyi)
  supplierId Int? // ta'minotchi (POSTAVSHIK)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  sales        ProductSales[]
  nameMismatch ProductNameMismatch?
  orderItems   PurchaseOrderItem[]

  @@index([categoryId])
  @@index([supplierId])
}

// Kunlik sotuv faylidagi nom master nomidan farq qilsa — review uchun saqlanadi.
// Admin Moslanmagan → "Nom farqi" tabida: yangilaydi yoki master nomini saqlaydi.
model ProductNameMismatch {
  id             Int      @id @default(autoincrement())
  productId      Int      @unique
  fileName       String // sotuv faylidagi nom
  uploadedFileId Int?
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Ta'minotchi (POSTAVSHIK) — sku.xlsx'dagi yetkazib beruvchi. Mahsulotga 1:N.
model Supplier {
  id        Int             @id @default(autoincrement())
  name      String          @unique // masalan "2-O'RIKZOR BOZOR"
  sortOrder Int             @default(0)
  products  Product[]
  orders    PurchaseOrder[]
}

// Zakaz — ta'minotchiga sotib olish buyurtmasi (kategoriya menejeri yaratadi).
model PurchaseOrder {
  id          Int         @id @default(autoincrement())
  supplierId  Int
  createdById Int // yaratgan foydalanuvchi (menejer/admin)
  status      OrderStatus @default(DRAFT)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sentAt      DateTime?
  receivedAt  DateTime?

  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([createdById])
  @@index([status])
}

model PurchaseOrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal @db.Decimal(20, 3)
  price     Decimal @db.Decimal(20, 2) // dona narxi

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId])
}

// Master sotuv fakti — SKU × filial × davr. Qayta yuklashda upsert (ustiga yoziladi).
model ProductSales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  productId      Int
  branchId       Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  stockQty       Decimal? @db.Decimal(20, 3) // Остаток (qoldiq dona)
  soldQty        Decimal? @db.Decimal(20, 3) // Количество (sotilgan dona)
  amount         Decimal  @db.Decimal(20, 2) // Продажи (savdo summasi)
  costAmount     Decimal? @db.Decimal(20, 2) // Себестоимость (tannarx)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([productId, periodStart, periodEnd])
  @@index([uploadedFileId])
}
