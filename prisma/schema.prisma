// Analitika BizBop — supermarket savdo analitika platformasi
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SYSTEM_ADMIN // to'liq huquq — barcha tahrir + Tizim bo'limi (oldingi ADMIN)
  ADMIN // read-only — Tizimdan boshqa hammasini ko'radi, o'zgartira olmaydi
  VIEWER // eskirgan — ishlatilmaydi (migratsiyada CAT_MANAGER'ga o'tkazilgan). UI'da yo'q.
  CAT_MANAGER
  CEO
  SUPPLYCHAIN // ta'minot zanjiri: analitika/sotuv/spisaniya ko'radi + yetkazib beruvchilarni boshqaradi
  HEAD_CAT_MANAGER // kategoriya menejerlari boshi: BARCHA kategoriyalar bo'yicha menejer ishi + yetkazib beruvchilarni ko'rish
  MERCHANDISER // merchandayzer — faqat Promo (Aksiyalar) bo'limini ko'radi/tahrirlaydi
  OPERATOR // operator — faqat Hisobdan chiqarish va Sverkani KUZATADI (read-only)
}

// Promo (Aksiyalar) turi — har biri odatiy davom etish muddatiga ega
enum PromoType {
  KUN_TAKLIFI // Kun taklifi — 1 kun
  HAFTA_CHEGIRMA // Hafta chegirmasi — 7 kun
  BIZBOP_NARX // Bizbop narx — 1 oy/doimiy (endDate null bo'lishi mumkin)
  AAARZON // A-a-arzon narx! — 14 kun
  FLASH // Flash/bayram aksiyalari
}

// Promo kampaniya holati
enum PromoStatus {
  DRAFT // Qoralama
  ACTIVE // Faol
  ENDED // Tugadi
  CANCELLED // Bekor qilindi
}

// Zakaz (sotib olish buyurtmasi) holati — to'liq workflow:
// menejer yaratadi → tasdiqqa → supplychain tasdiqlaydi → yuboradi →
// yetkazib beruvchi qabul qiladi → yetib keladi (fakt solishtiriladi)
enum OrderStatus {
  DRAFT // Qoralama (menejer)
  PENDING // Tasdiqda (supplychain navbatida)
  APPROVED // Tasdiqlandi (supplychain)
  SENT // Yetkazib beruvchiga yuborildi
  ACCEPTED // Zakaz qabul qilindi (yetkazib beruvchi)
  RECEIVED // Yetib keldi (fakt kiritiladi)
  RETURNED // Qaytarildi
}

enum FileType {
  SALES
  METRICS
  VISITS
}

// PME analyze — SKU'ning ikkinchi o'lchamdagi segmenti (qo'lda biriktiriladi)
enum Segment {
  PREMIUM
  MEDIUM
  EASY
}

// Ombor → filial taqsimot hujjati holati
enum DistributionStatus {
  DRAFT // Qoralama (tahrirlanadi)
  CONFIRMED // Tasdiqlandi (ombor qoldig'idan ayirildi, qulflangan)
  CANCELLED // Bekor qilindi
}

// Filiallararo ko'chirish hujjati holati
enum TransferStatus {
  DRAFT // Qoralama (tahrirlanadi)
  CONFIRMED // Tasdiqlandi (qulflangan — hujjat sifatida)
  CANCELLED // Bekor qilindi
}

enum AliasSource {
  SALES
  VISITS
  SR
  PLANS
}

enum UploadStatus {
  SUCCESS
  FAILED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CAT_MANAGER) // asosiy rol — default kirish sahifasi, JWT
  extraRoles   Role[]   @default([]) // qo'shimcha rollar; ruxsat = role + extraRoles birlashmasi (union)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploads           UploadedFile[]
  managedCategories CategoryManager[] // kategoriya menejeri javobgar kategoriyalari
  purchaseOrders    PurchaseOrder[]
  expenses          Expense[]
  distributions     Distribution[]
  branchTransfers   BranchTransfer[]
  batches           ProductBatch[]
  promoCampaigns    PromoCampaign[] // yaratgan promo aksiyalari (createdBy)
}

// Kategoriya menejeri ↔ kategoriya (ko'p-ko'p): bir xodim bir nechta kategoriyaga javobgar.
model CategoryManager {
  userId     Int
  categoryId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
}

model Branch {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  chiqimFilial  String? // bizbop (spisaniya bot) yozuvlar.filial nomi — chiqim filtri uchun; null bo'lsa name ishlatiladi. Sozlamalar → Filiallar'da bog'lanadi
  sortOrder     Int      @default(0)
  sverkaTopicId Int? // sverka guruhidagi topic (message_thread_id) — Sozlamalar → Sverka'da
  createdAt     DateTime @default(now())

  aliases        BranchAlias[]
  sales          CategorySales[]
  productSales   ProductSales[]
  metrics        DailyMetrics[]
  receiptMetrics DailyReceiptMetric[]
  visits         DailyVisits[]
  uploads        UploadedFile[]
  salesPlans     SalesPlan[]
  marginPlans    MarginPlan[]
  forecastCurves ForecastCurve[]
  forecastRuns   ForecastRun[]
  forecastDays   ForecastDay[]
  distributions  Distribution[]
  transfersFrom  BranchTransfer[]     @relation("TransferFrom")
  transfersTo    BranchTransfer[]     @relation("TransferTo")
  batches        ProductBatch[]
  promoCampaigns PromoCampaign[] // shu filialga oid promo aksiyalar (null = barcha filiallar)
  orderItemBranches PurchaseOrderItemBranch[] // zakaz qatorlarining shu filialga taqsimoti
  supplierProfiles  SupplierBranchProfile[] // yetkazib beruvchilarning shu filial profili
}

model BranchAlias {
  id       Int         @id @default(autoincrement())
  branchId Int
  alias    String
  source   AliasSource

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([alias, source])
  @@index([branchId])
}

model CategoryGroup {
  id        Int    @id @default(autoincrement())
  name      String @unique
  code      Int?   @unique // 1C KOD — bo'lim identifikatori
  sortOrder Int    @default(0)

  categories     Category[]
  forecastCurves ForecastCurve[]
  forecastRuns   ForecastRun[]
}

model Category {
  id        Int    @id @default(autoincrement())
  name      String // 1C'da bir xil nom turli joyda bo'lishi mumkin — farqlash code orqali
  code      Int?   @unique // 1C KOD — kategoriya/subkategoriya identifikatori va matching kaliti
  sortOrder Int    @default(0)
  groupId   Int?
  parentId  Int?

  group    CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parent   Category?      @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryParent")

  aliases        CategoryAlias[]
  sales          CategorySales[]
  products       Product[]
  managers       CategoryManager[]
  salesPlans     SalesPlan[]
  marginPlans    MarginPlan[]
  spisaniyaLinks SpisaniyaCategoryLink[]

  @@index([parentId]) // scope filtrlari (subkat → ota-kategoriya) tezligi uchun
  @@index([groupId])
}

model CategoryAlias {
  id         Int    @id @default(autoincrement())
  categoryId Int
  alias      String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([alias])
  @@index([categoryId])
}

// Sotuv fayllaridan keladigan kategoriya bo'yicha summalar.
// Period 1 kun yoki bir necha kun bo'lishi mumkin (29.04 — bir kun, 1(2).xlsx — 29 kun).
model CategorySales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  categoryId     Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  amount         Decimal  @db.Decimal(20, 2)
  costAmount     Decimal? @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([categoryId, periodStart, periodEnd])
  // Davr-overlap so'rovlari uchun periodEnd yetakchi range (ProductSales bilan bir xil sabab).
  @@index([periodEnd, periodStart])
  @@index([uploadedFileId])
}

// sr.xlsx fayllaridan — kunlik chek metrikalari (filial majburiy).
model DailyMetrics {
  id                 Int      @id @default(autoincrement())
  uploadedFileId     Int
  branchId           Int
  date               DateTime @db.Date
  receiptCount       Int
  receiptTotal       Decimal  @db.Decimal(20, 2)
  avgItemsPerReceipt Decimal  @db.Decimal(10, 4)
  avgReceipt         Decimal  @db.Decimal(20, 2)
  bigPurchaseLevel   Decimal  @db.Decimal(20, 2)
  smallPurchaseLevel Decimal  @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// export (1).xlsx — kunlik tashriflar (4 filialdan biri har qatorga).
model DailyVisits {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  date           DateTime @db.Date
  visitCount     Int

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// Yuklangan har bir fayl audit + dublikat oldini olish uchun saqlanadi.
model UploadedFile {
  id              Int          @id @default(autoincrement())
  label           String // admin tomonidan qo'yilgan nom (chalg'imaslik uchun)
  originalName    String
  fileHash        String       @unique // sha256 — bir xil fayl 2 marta yuklanmaydi
  fileType        FileType
  branchId        Int? // METRICS uchun majburiy, SALES bir filialli bo'lsa shunchaki
  periodStart     DateTime?    @db.Date
  periodEnd       DateTime?    @db.Date
  yearOverride    Int? // VISITS faylda yil bo'lmaganda admin tanlaydi
  templateVersion String? // sotuv shabloni versiyasi (header signaturasidan: v1/v2/v3)
  rowCount        Int          @default(0)
  status          UploadStatus @default(SUCCESS)
  errorMessage    String?
  uploadedById    Int
  createdAt       DateTime     @default(now())

  uploadedBy User    @relation(fields: [uploadedById], references: [id])
  branch     Branch? @relation(fields: [branchId], references: [id])

  sales        CategorySales[]
  productSales ProductSales[]
  metrics      DailyMetrics[]
  visits       DailyVisits[]

  @@index([fileType, periodStart, periodEnd])
  @@index([uploadedById])
}

// Kunlik chek metrikalari — QO'LDA kiritiladi (sr.xlsx emas). Filial × sana.
// Chek soni va chekdagi o'rtacha tovar soni (Tashriflar bo'limi tabida).
model DailyReceiptMetric {
  id              Int      @id @default(autoincrement())
  branchId        Int
  date            DateTime @db.Date
  receiptCount    Int      @default(0) // kunlik chek soni
  itemsPerReceipt Decimal  @default(0) @db.Decimal(10, 3) // chekdagi o'rtacha tovar soni
  createdById     Int? // kim kiritdi (audit)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
}

// ─── Master baza: mahsulot (SKU) darajasidagi ma'lumot ───────────────────────
// Yangi sotuv shabloni (ShablonSotuv.xlsx) mahsulot darajasida keladi.
// Product = 1C mahsulot katalogi; ProductSales = SKU × filial × davr fakt jadval.

model Product {
  id         Int      @id @default(autoincrement())
  code       Int      @unique // 1C mahsulot kodi
  name       String
  categoryId Int? // tegishli kategoriya/subkategoriya (iyerarxiyadagi joyi)
  supplierId Int? // yetkazib beruvchi (POSTAVSHIK)
  agentId    Int? // yetkazib beruvchi ichidagi agent (brend) — SKU shu agentga biriktiriladi
  segment    Segment? // PME analyze segmenti (Premium/Medium/Easy) — qo'lda biriktiriladi
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Joriy holat — har yuklashda denormalizatsiya qilinadi (OOS/zakaz so'rovi
  // ProductSales tarixini skanlamasligi uchun). Manba — eng so'nggi davr.
  currentStock   Decimal?  @db.Decimal(20, 3) // so'nggi davrdagi qoldiq (filiallar yig'indisi)
  currentSold    Decimal?  @db.Decimal(20, 3) // so'nggi davrdagi sotuv (dona)
  abcClass       String?   @db.Char(1) // ABC sinfi (standart 3 oylik oyna) — sotuv yuklashda yangilanadi
  xyzClass       String?   @db.Char(1) // XYZ sinfi (talab barqarorligi) — sotuv yuklashda yangilanadi
  leadTimeDays   Int? // zakazdan kelguncha kunlar — yetkazib beruvchi profilida kiritiladi
  archivedAt     DateTime? // no-aktiv (arxiv) — buyurtma/OOS/Stockday'dan chiqadi, tarix saqlanadi
  packSize       Decimal?  @db.Decimal(20, 3) // pachkadagi dona soni/hajmi (og'irlik/hajm uchun kasr ham) — buyurtmada eslab qolinadi
  purchasePrice  Decimal?  @db.Decimal(20, 2) // kelishilgan sotib olish narxi (dona) — zakazdan eslab qolinadi
  lastSalePeriod DateTime? @db.Date // so'nggi yuklangan davr (eskini bosib o'tmaslik uchun)

  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier          Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  agent             Agent?               @relation(fields: [agentId], references: [id], onDelete: SetNull)
  sales             ProductSales[]
  nameMismatch      ProductNameMismatch?
  orderItems        PurchaseOrderItem[]
  warehouseStock    WarehouseStock?
  distributionItems DistributionItem[]
  transferItems     BranchTransferItem[]
  batches           ProductBatch[]
  promoItems        PromoItem[] // aksiyalardagi qatnashuvi

  @@index([categoryId])
  @@index([supplierId])
  @@index([agentId])
  @@index([segment])
}

// Kunlik sotuv faylidagi nom master nomidan farq qilsa — review uchun saqlanadi.
// Admin Moslanmagan → "Nom farqi" tabida: yangilaydi yoki master nomini saqlaydi.
model ProductNameMismatch {
  id             Int      @id @default(autoincrement())
  productId      Int      @unique
  fileName       String // sotuv faylidagi nom
  uploadedFileId Int?
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Yetkazib beruvchi (POSTAVSHIK) — sku.xlsx'dagi yetkazib beruvchi. Mahsulotga 1:N.
model Supplier {
  id            Int     @id @default(autoincrement())
  name          String  @unique // masalan "2-O'RIKZOR BOZOR"
  sortOrder     Int     @default(0)
  // ── Profil ──
  rating        Int? // 1..5 yulduz (menejer bahosi)
  ratingNote    String? // baho izohi
  phone         String?
  contactName   String? // mas'ul shaxs
  // Haftalik takrorlanuvchi zakaz qabul kunlari: 0=Yakshanba ... 6=Shanba (JS getUTCDay)
  orderWeekdays Int[]   @default([])

  // ── Shartlar (SUPPLYCHAIN tahrirlaydi) ──
  paymentType       String? // "PERECHISLENIYE" | "NAQD"
  ehfMatch          Boolean? // Perechisleniya fakturada (EHF) 1:1 aks etadimi
  otsrochkaDays     Int? // otsrochka (30/45/60/90)
  debitorHas        Boolean? // debitorka limiti bormi
  debitorLimit      Decimal? @db.Decimal(18, 2) // debitorka limiti summasi
  discountPct       Decimal? @db.Decimal(6, 2) // asosiy chegirma %
  marketingDiscount Boolean? // marketing skidkasi bormi
  retrobonusPct     Decimal? @db.Decimal(6, 2) // retrobonus %
  agentMerchNote    String? // agent/merchandiser ishlash tartibi
  promoSystem       String? // promo tizimi izohi
  promoCalendar     Boolean? // promo kalendari tuzilganmi
  // Kontaktlar (ism + tel)
  responsibleRole   String? // Supervayzer/Reg.menejer/Diller/Filial rahbari/Direktor
  responsibleName   String?
  responsiblePhone  String?
  sverkaName        String? // sverka bo'limi
  sverkaPhone       String?
  accountingName    String? // buxgalteriya (EHF mas'uli)
  accountingPhone   String?
  logisticsName     String? // dastavka (logistika)
  logisticsPhone    String?

  products       Product[]
  orders         PurchaseOrder[]
  contracts      SupplierContract[]
  sverkalar      SverkaRecord[]
  orderDays      SupplierOrderDay[]
  agents         Agent[]
  branchProfiles SupplierBranchProfile[] // filial bo'yicha profil ma'lumotlari
}

// Yetkazib beruvchi × filial profil ma'lumotlari (✓ per-filial maydonlar)
model SupplierBranchProfile {
  id              Int      @id @default(autoincrement())
  supplierId      Int
  branchId        Int
  shelfLengthCm   Int? // dolya polka uzunligi (sm)
  faceCount       Int? // face soni
  skuCount        Int? // SKU soni (shu filialda)
  orderDay        String? // zakaz kuni (hafta kuni — ma'lumot)
  deliveryDays    Int? // dastavka necha kun
  deliveryWeekday String? // dastavka qaysi kun
  deliveryTime    String? // dastavka qaysi soat
  dpPaymentTerms  String? // qo'shimcha polka (DP) to'lov sharti
  forecastYearly  Decimal? @db.Decimal(18, 2) // sotuv prognozi (yillik)
  forecastMonthly Decimal? @db.Decimal(18, 2) // sotuv prognozi (oylik)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([supplierId, branchId])
  @@index([branchId])
}

// Agent (BREND) — yetkazib beruvchi ichidagi alohida brend/vakil. Postavshikning
// SKU'lari agentlarga taqsimlanadi; har agent o'z kontakti va zakaz kunlari bilan,
// zakaz har agentga ALOHIDA beriladi (PurchaseOrder.agentId, alohida nakladnoy).
model Agent {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  name        String // brend nomi (yetkazib beruvchi ichida unikal)
  phone       String?
  contactName String? // mas'ul shaxs
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  // Haftalik takrorlanuvchi zakaz qabul kunlari: 0=Yakshanba ... 6=Shanba (JS getUTCDay)
  orderWeekdays Int[]  @default([])

  supplier  Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products  Product[]
  orderDays AgentOrderDay[]
  orders    PurchaseOrder[]

  @@unique([supplierId, name])
  @@index([supplierId])
}

// Yetkazib beruvchi bilan shartnoma — hujjat fayli tashqi havola (Drive va h.k.) sifatida.
model SupplierContract {
  id         Int       @id @default(autoincrement())
  supplierId Int
  title      String // masalan "Yetkazib berish shartnomasi 2026"
  number     String? // shartnoma raqami
  signedAt   DateTime? @db.Date // imzolangan sana
  endDate    DateTime? @db.Date // amal qilish muddati
  amount     Decimal?  @db.Decimal(20, 2) // shartnoma summasi (bo'lsa)
  url        String? // hujjat havolasi (Google Drive va h.k.)
  note       String?
  createdAt  DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// Zakaz — yetkazib beruvchiga sotib olish buyurtmasi (kategoriya menejeri yaratadi).
model PurchaseOrder {
  id          Int         @id @default(autoincrement())
  supplierId  Int
  agentId     Int? // agent (brend) — zakaz har agentga alohida; agentsiz zakazda null
  createdById Int // yaratgan foydalanuvchi (menejer/admin)
  status      OrderStatus @default(DRAFT)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sentAt      DateTime?
  receivedAt  DateTime?
  rating      Int? // yetib kelgan zakaz bahosi (1..5) — yetkazib beruvchi o'rtachasiga kiradi
  ratingNote  String? // baho izohi (ixtiyoriy)
  ratedAt     DateTime? // baho qo'yilgan vaqt

  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  agent     Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdBy User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([agentId])
  @@index([createdById])
  @@index([status])
}

model PurchaseOrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal  @db.Decimal(20, 3)
  price     Decimal  @db.Decimal(20, 2) // dona narxi
  packCount Decimal? @db.Decimal(20, 3) // nechta blok/yashik buyurtma qilindi (kasr ham bo'lishi mumkin)
  packSize  Decimal? @db.Decimal(20, 3) // o'sha paytdagi pachka soni/hajmi — quantity = packCount × packSize
  factQty   Decimal? @db.Decimal(20, 3) // FAKT yetib kelgan miqdor — solishtirish uchun

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchQtys PurchaseOrderItemBranch[] // filial bo'yicha taqsimot (quantity = yig'indisi)

  @@unique([orderId, productId])
  @@index([productId])
}

// Zakaz qatori × filial — har filialga buyurtma miqdori. PurchaseOrderItem.quantity =
// shu qatorlar yig'indisi (jami). Eski (filialsiz) zakazlarda bu qatorlar bo'lmaydi —
// detal/nakladnoy avtomatik "faqat jami" ko'rinishga tushadi (backward-compatible).
model PurchaseOrderItemBranch {
  id          Int     @id @default(autoincrement())
  orderItemId Int
  branchId    Int
  quantity    Decimal @db.Decimal(20, 3)

  orderItem PurchaseOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  branch    Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, branchId])
  @@index([branchId])
}

// Master sotuv fakti — SKU × filial × davr. Qayta yuklashda upsert (ustiga yoziladi).
model ProductSales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  productId      Int
  branchId       Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  stockQty       Decimal? @db.Decimal(20, 3) // Остаток (qoldiq dona)
  soldQty        Decimal? @db.Decimal(20, 3) // Количество (sotilgan dona)
  amount         Decimal  @db.Decimal(20, 2) // Продажи / Сумма (savdo summasi)
  costAmount     Decimal? @db.Decimal(20, 2) // Себестоимость / Сумма (tannarx summasi)
  salePrice      Decimal? @db.Decimal(20, 3) // Продажи / Цена — sotuv narxi (dona, tayyor; faylda bo'lsa)
  costPrice      Decimal? @db.Decimal(20, 3) // Себестоимость / Цена — tannarx narxi (dona, tayyor; faylda bo'lsa)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([productId, periodStart, periodEnd])
  @@index([productId, branchId, periodEnd(sort: Desc)]) // OOS/Stockday "latest snapshot" DISTINCT ON tartibi
  // Davr-overlap (periodStart <= end AND periodEnd >= start): periodEnd yetakchi range —
  // yaqin davr so'rovlarida eski qatorlarni chetlab o'tadi (analytics/marja skanlari).
  @@index([periodEnd, periodStart])
  @@index([uploadedFileId])
}

// Oylik sotuv rejasi — subkategoriya × filial × yil/oy
model SalesPlan {
  id         Int      @id @default(autoincrement())
  branchId   Int
  categoryId Int
  year       Int
  month      Int // 1–12
  amount     Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, year, month])
  @@index([branchId, year, month])
}

// Spisaniya (chiqim) kategoriya ko'prigi — bizbop kategoriya nomi → Iyerarxiya subkat.
// bizbop ALOHIDA bazada (cross-DB join yo'q) — shu sabab nom bo'yicha bog'laymiz.
// yozuvlar.kategoriya (matn) → botName → categoryId → bo'lim/kat/subkat rollup.
model SpisaniyaCategoryLink {
  id         Int      @id @default(autoincrement())
  botName    String   @unique // bizbop kategoriya nomi (yozuvlar.kategoriya bilan mos)
  categoryId Int // Iyerarxiya kategoriya/subkategoriya id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

// Sotuv bo'limi moliyasi — harajatlar (filialsiz, umumiy ro'yxat).
// Summa = miqdor × narx (serverda hisoblanadi).
model Expense {
  id          Int       @id @default(autoincrement())
  name        String // harajat nomi
  quantity    Decimal   @db.Decimal(20, 3) // miqdor
  unitPrice   Decimal   @db.Decimal(20, 2) // narx (bir birlik)
  amount      Decimal   @db.Decimal(20, 2) // summa = quantity × unitPrice
  spentAt     DateTime  @db.Date // harajat qilingan sana
  createdById Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime? // soft delete — moliyaviy yozuv butunlay o'chmaydi

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([spentAt])
  @@index([spentAt, deletedAt]) // finans sahifasi filtri: spentAt oralig'i + deletedAt IS NULL
  @@index([createdById])
}

// Marja rejasi — subkategoriya × filial (vaqtsiz, o'zgarganda yangilanadi)
model MarginPlan {
  id         Int      @id @default(autoincrement())
  branchId   Int
  categoryId Int
  marginPct  Decimal  @default(0) @db.Decimal(6, 2)
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId])
  @@index([branchId])
  @@index([categoryId])
}

// AI prognoz egri chizig'i — filial × bo'lim × oy uchun kunlik og'irlik (taqsimot shakli).
// Og'irliklar oy bo'yicha yig'indisi = 1. Kunlik prognoz = bo'lim oylik rejasi × weight.
// Shu sabab kunlik prognoz yig'indisi har doim aniq rejaga teng bo'ladi.
model ForecastCurve {
  id       Int      @id @default(autoincrement())
  branchId Int
  groupId  Int
  year     Int
  month    Int // 1–12
  date     DateTime @db.Date
  weight   Decimal  @db.Decimal(9, 8)

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  group  CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([branchId, groupId, year, month, date])
  @@index([branchId, year, month])
  @@index([date])
}

// Kunlik prognoz summasi — filial × oy × kun (barcha bo'limlar yig'indisi).
// Dashboard va Rejalar "Kunlik prognoz" tab shu jadvalni o'qiydi/tahrirlaydi.
// locked=true — admin qo'lda o'zgartirgan kun; qayta taqsimlashda o'zgarmaydi.
// Yig'indi (oy bo'yicha) = filial oylik reja summasiga teng (tahrirda saqlanadi).
model ForecastDay {
  id       Int      @id @default(autoincrement())
  branchId Int
  year     Int
  month    Int
  date     DateTime @db.Date
  amount   Decimal  @db.Decimal(18, 2)
  locked   Boolean  @default(false)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, year, month, date])
  @@index([date])
  @@index([branchId, year, month])
}

// Prognoz yaratish jurnali — filial × bo'lim × oy uchun AI izohi va meta.
model ForecastRun {
  id        Int      @id @default(autoincrement())
  branchId  Int
  groupId   Int
  year      Int
  month     Int
  model     String // ishlatilgan model (yoki "fallback")
  rationale String // AI ning qisqa izohi (nega shunday taqsimladi)
  createdAt DateTime @default(now())

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  group  CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([branchId, groupId, year, month])
  @@index([branchId, year, month])
}

// ─── Yetkazib beruvchi anketasi (supplier.oilagroup.uz) ──────────────────────────────
// Forma maydonlari sozlanuvchan — Tizim → Anketa bo'limida tahrirlanadi.
// Bo'lim (section) alohida entity — bo'sh bo'lim bo'lishi, nomi tahrirlanishi mumkin.
model AnketaSection {
  id        Int           @id @default(autoincrement())
  title     String // bo'lim sarlavhasi (KOMPANIYA HAQIDA UMUMIY MA'LUMOT ...)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  fields    AnketaField[]
}

model AnketaField {
  id        Int           @id @default(autoincrement())
  sectionId Int
  section   AnketaSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label     String
  type      String        @default("text") // text | textarea | number | yesno | consent
  required  Boolean       @default(false)
  sortOrder Int           @default(0) // bo'lim ichidagi tartib
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@index([sectionId, sortOrder])
}

// Yuborilgan anketalar — javoblar JSON ({ fieldId: qiymat })
model AnketaSubmission {
  id          Int      @id @default(autoincrement())
  companyName String // tezkor ro'yxat uchun (Kompaniya nomi javobidan)
  phone       String?
  answers     Json
  status      String   @default("NEW") // NEW | REVIEWED
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

// ─── Sverka — yetkazib beruvchi bilan solishtirish yozuvi (Telegram Mini App) ──
// Kiritish tartibi: sana → firma (Supplier'dan tanlanadi) → sklad → kontragent →
// dagavor → summa + nakladnoy rasmi (Telegram file_id, rasm-yukla sxemasi).
model SverkaRecord {
  id         Int      @id @default(autoincrement())
  sana       DateTime @db.Date
  supplierId Int? // firma — yetkazib beruvchilar bazasidan (o'chsa NULL, nom qoladi)
  firmaNomi  String // tanlash paytidagi nom (snapshot)
  sklad      String
  qabulQildi String // tovarni qabul qilgan xodim (Sozlamalar → Sverka ro'yxatidan)
  dagavor    String
  summa      Decimal  @db.Decimal(20, 2)
  rasmFileId String // nakladnoy rasmi — Telegram file_id
  tgUserId   BigInt // kim kiritdi (Telegram ID)
  tgUserName String?
  createdAt  DateTime @default(now())

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([sana])
  @@index([supplierId])
  @@index([createdAt])
}

// Sverka botiga ruxsat berilgan xodimlar (alohida bot, alohida ro'yxat —
// ERP Sverka sahifasida SA/SUPPLYCHAIN boshqaradi).
model SverkaXodim {
  id        Int      @id @default(autoincrement())
  tgUserId  BigInt   @unique
  ism       String?
  createdAt DateTime @default(now())
}

// Umumiy kalit-qiymat sozlamalar (asosiy baza) — masalan SVERKA_GROUP_CHAT_ID
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Zakaz qabul kunlari — ANIQ SANALAR (kalendardan bittalab belgilanadi).
// orderWeekdays (haftalik takror) o'rnini bosdi; eski ustun meros sifatida qoladi.
model SupplierOrderDay {
  id         Int      @id @default(autoincrement())
  supplierId Int
  sana       DateTime @db.Date

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, sana])
  @@index([sana])
}

// Markaziy ombor qoldig'i — kunlik import (kod → qoldiq) bilan yangilanadi (1C sotuv
// faylida yo'q). Bitta markaziy ombor; snapshot (oxirgi import). Taqsimot shu asosda.
model WarehouseStock {
  id        Int      @id @default(autoincrement())
  productId Int      @unique
  qty       Decimal  @default(0) @db.Decimal(20, 3)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Ombor → filial taqsimot hujjati (tizim yaratadi). Tasdiqlanganda ombor qoldig'idan ayiriladi.
model Distribution {
  id          Int                @id @default(autoincrement())
  branchId    Int // qabul qiluvchi filial
  status      DistributionStatus @default(DRAFT)
  targetDays  Int                @default(7) // qoplash kunlari (tavsiya uchun)
  note        String?
  createdById Int
  createdAt   DateTime           @default(now())
  confirmedAt DateTime?

  branch    Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     DistributionItem[]

  @@index([branchId])
  @@index([status])
}

model DistributionItem {
  id             Int     @id @default(autoincrement())
  distributionId Int
  productId      Int
  qty            Decimal @db.Decimal(20, 3) // taqsimlanadigan miqdor

  distribution Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([distributionId, productId])
  @@index([productId])
}

// Filiallararo ko'chirish hujjati — manba filialdagi ortiqcha/o'lik qoldiqni qabul
// qiluvchi filialga ko'chirish (shoshilinch OOS uchun, markaziy ombordan o'tmasdan).
// Filial qoldig'i kunlik importdan keladi (o'zgaruvchan jadval yo'q) — tasdiqlash
// faqat hujjatni qulflaydi, qoldiq ayirilmaydi (import qayta yangilaydi).
model BranchTransfer {
  id           Int            @id @default(autoincrement())
  fromBranchId Int // manba (ortiqcha/o'lik qoldiqli)
  toBranchId   Int // qabul qiluvchi (kam/OOS)
  status       TransferStatus @default(DRAFT)
  targetDays   Int            @default(7) // qoplash kunlari (tavsiya uchun)
  note         String?
  createdById  Int
  createdAt    DateTime       @default(now())
  confirmedAt  DateTime?

  fromBranch Branch               @relation("TransferFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranch   Branch               @relation("TransferTo", fields: [toBranchId], references: [id], onDelete: Cascade)
  createdBy  User                 @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items      BranchTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
}

model BranchTransferItem {
  id         Int     @id @default(autoincrement())
  transferId Int
  productId  Int
  qty        Decimal @db.Decimal(20, 3) // ko'chiriladigan miqdor

  transfer BranchTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([transferId, productId])
  @@index([productId])
}

// Mahsulot partiyasi (lot) — yaroqlilik MUDDATI nazorati uchun. Qo'lda yoki fayl import
// bilan kiritiladi. branchId null = markaziy ombor. Markdown (chegirma) xavfi: qoldiq vs
// muddatgacha sotiladigan miqdor (kunlik o'rtacha × qolgan kun). Bir joyda bir muddat = bitta
// partiya (productId + branchId + expiryDate unikal — COALESCE indeks migratsiyada).
model ProductBatch {
  id          Int      @id @default(autoincrement())
  productId   Int
  branchId    Int? // null = markaziy ombor
  qty         Decimal  @db.Decimal(20, 3) // partiyadagi qoldiq
  expiryDate  DateTime @db.Date // yaroqlilik muddati (tugash sanasi)
  note        String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([branchId])
  @@index([expiryDate])
}

// Agent (brend) zakaz qabul kunlari — SupplierOrderDay'ga parallel, lekin agent darajasida.
model AgentOrderDay {
  id      Int      @id @default(autoincrement())
  agentId Int
  sana    DateTime @db.Date

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, sana])
  @@index([sana])
}

// Sverka "Qabul qildi" ro'yxati — qabul qiluvchi xodim ismlari
// (Sozlamalar → Sverka'da yuritiladi, mini app'da tanlanadi).
model SverkaQabulchi {
  id        Int      @id @default(autoincrement())
  ism       String   @unique
  createdAt DateTime @default(now())
}

// Promo (Aksiya) kampaniyasi — bir turdagi, sanali aksiya.
// branchId null bo'lsa BARCHA filiallarga tegishli, aks holda bitta filialga.
model PromoCampaign {
  id          Int         @id @default(autoincrement())
  type        PromoType
  title       String
  status      PromoStatus @default(DRAFT)
  startDate   DateTime    @db.Date
  endDate     DateTime?   @db.Date // null = BIZBOP_NARX doimiy
  branchId    Int? // null = barcha filiallar
  note        String?
  createdById Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch     Branch?          @relation(fields: [branchId], references: [id])
  createdBy  User             @relation(fields: [createdById], references: [id])
  items      PromoItem[]
  itemGroups PromoItemGroup[]

  @@index([type, status])
  @@index([startDate, endDate])
  @@index([branchId])
  @@index([createdById])
}

// Aksiya ICHIDAGI SKU guruhi — bir mahsulotning har xil ta'm/turlari (mas. "Sochnaya
// Dolina Sok 1L" → Abrikos, Persik, …). Faqat shu kampaniyaga tegishli (qayta ishlatilmaydi).
// Guruh o'chsa SKU'lar guruhsiz bo'lib qoladi (PromoItem.groupId → SetNull).
model PromoItemGroup {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  name          String
  sortOrder     Int      @default(0)
  designTitle   String? // dizayn banner uchun chiroyli nom (uz); null = guruh nomi fallback
  designTitleRu String? // ixtiyoriy ru qator (null = ko'rsatilmaydi)
  imageData     String?  @db.Text // oq/shaffof fonli mahsulot rasmi — "data:image/png;base64,..."
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign PromoCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  items    PromoItem[]

  @@index([campaignId])
}

// Promo kampaniyasidagi alohida tovar — narxlar dona uchun.
model PromoItem {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  productId     Int
  groupId       Int? // aksiya ichidagi SKU guruhi (ixtiyoriy; null = guruhsiz)
  regularPrice  Decimal  @db.Decimal(20, 2) // sotilish (oddiy) narxi
  promoPrice    Decimal  @db.Decimal(20, 2) // aksiya narxi
  promoLimit    Decimal? @db.Decimal(20, 3) // aksiya limiti (dona, kasr ham bo'lishi mumkin)
  priceReturned Boolean? // aksiya tugagach narx asliga qaytdimi (hisobot to'ldiradi)
  designTitle   String? // dizayn banner uchun chiroyli nom (uz; guruhsiz SKU uchun) — null = Product.name fallback
  designTitleRu String? // ixtiyoriy ru qator (null = ko'rsatilmaydi)
  imageData     String?  @db.Text // oq/shaffof fonli mahsulot rasmi — "data:image/png;base64,..."
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign PromoCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  group    PromoItemGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([campaignId, productId])
  @@index([productId])
  @@index([campaignId])
  @@index([groupId])
}
