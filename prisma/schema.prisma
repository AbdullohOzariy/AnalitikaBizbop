// Analitika BizBop — supermarket savdo analitika platformasi
// Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SYSTEM_ADMIN // to'liq huquq — barcha tahrir + Tizim bo'limi (oldingi ADMIN)
  ADMIN // read-only — Tizimdan boshqa hammasini ko'radi, o'zgartira olmaydi
  VIEWER // eskirgan — ishlatilmaydi (migratsiyada CAT_MANAGER'ga o'tkazilgan). UI'da yo'q.
  CAT_MANAGER
  CEO
  SUPPLYCHAIN // ta'minot zanjiri: analitika/sotuv/spisaniya ko'radi + yetkazib beruvchilarni boshqaradi
  HEAD_CAT_MANAGER // kategoriya menejerlari boshi: BARCHA kategoriyalar bo'yicha menejer ishi + yetkazib beruvchilarni ko'rish
}

// Zakaz (sotib olish buyurtmasi) holati
enum OrderStatus {
  DRAFT // Qoralama
  SENT // Yuborildi
  RECEIVED // Qabul qilindi
  RETURNED // Qaytarildi
}

enum FileType {
  SALES
  METRICS
  VISITS
}

enum AliasSource {
  SALES
  VISITS
  SR
  PLANS
}

enum UploadStatus {
  SUCCESS
  FAILED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CAT_MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploads           UploadedFile[]
  managedCategories CategoryManager[] // kategoriya menejeri javobgar kategoriyalari
  purchaseOrders    PurchaseOrder[]
  expenses          Expense[]
}

// Kategoriya menejeri ↔ kategoriya (ko'p-ko'p): bir xodim bir nechta kategoriyaga javobgar.
model CategoryManager {
  userId     Int
  categoryId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
}

model Branch {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  sortOrder     Int      @default(0)
  sverkaTopicId Int? // sverka guruhidagi topic (message_thread_id) — Sozlamalar → Sverka'da
  createdAt     DateTime @default(now())

  aliases       BranchAlias[]
  sales         CategorySales[]
  productSales  ProductSales[]
  metrics       DailyMetrics[]
  receiptMetrics DailyReceiptMetric[]
  visits        DailyVisits[]
  uploads       UploadedFile[]
  salesPlans    SalesPlan[]
  marginPlans   MarginPlan[]
  forecastCurves ForecastCurve[]
  forecastRuns   ForecastRun[]
  forecastDays   ForecastDay[]
}

model BranchAlias {
  id       Int         @id @default(autoincrement())
  branchId Int
  alias    String
  source   AliasSource

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([alias, source])
  @@index([branchId])
}

model CategoryGroup {
  id        Int    @id @default(autoincrement())
  name      String @unique
  code      Int?   @unique // 1C KOD — bo'lim identifikatori
  sortOrder Int    @default(0)

  categories     Category[]
  forecastCurves ForecastCurve[]
  forecastRuns   ForecastRun[]
}

model Category {
  id        Int    @id @default(autoincrement())
  name      String // 1C'da bir xil nom turli joyda bo'lishi mumkin — farqlash code orqali
  code      Int?   @unique // 1C KOD — kategoriya/subkategoriya identifikatori va matching kaliti
  sortOrder Int    @default(0)
  groupId   Int?
  parentId  Int?

  group    CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parent   Category?      @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryParent")

  aliases        CategoryAlias[]
  sales          CategorySales[]
  products       Product[]
  managers       CategoryManager[]
  salesPlans     SalesPlan[]
  marginPlans    MarginPlan[]
  spisaniyaLinks SpisaniyaCategoryLink[]

  @@index([parentId]) // scope filtrlari (subkat → ota-kategoriya) tezligi uchun
  @@index([groupId])
}

model CategoryAlias {
  id         Int    @id @default(autoincrement())
  categoryId Int
  alias      String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([alias])
  @@index([categoryId])
}

// Sotuv fayllaridan keladigan kategoriya bo'yicha summalar.
// Period 1 kun yoki bir necha kun bo'lishi mumkin (29.04 — bir kun, 1(2).xlsx — 29 kun).
model CategorySales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  categoryId     Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  amount         Decimal  @db.Decimal(20, 2)
  costAmount     Decimal? @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([categoryId, periodStart, periodEnd])
  @@index([uploadedFileId])
}

// sr.xlsx fayllaridan — kunlik chek metrikalari (filial majburiy).
model DailyMetrics {
  id                   Int      @id @default(autoincrement())
  uploadedFileId       Int
  branchId             Int
  date                 DateTime @db.Date
  receiptCount         Int
  receiptTotal         Decimal  @db.Decimal(20, 2)
  avgItemsPerReceipt   Decimal  @db.Decimal(10, 4)
  avgReceipt           Decimal  @db.Decimal(20, 2)
  bigPurchaseLevel     Decimal  @db.Decimal(20, 2)
  smallPurchaseLevel   Decimal  @db.Decimal(20, 2)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// export (1).xlsx — kunlik tashriflar (4 filialdan biri har qatorga).
model DailyVisits {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  branchId       Int
  date           DateTime @db.Date
  visitCount     Int

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@index([branchId, date])
  @@index([uploadedFileId])
}

// Yuklangan har bir fayl audit + dublikat oldini olish uchun saqlanadi.
model UploadedFile {
  id           Int          @id @default(autoincrement())
  label        String       // admin tomonidan qo'yilgan nom (chalg'imaslik uchun)
  originalName String
  fileHash     String       @unique // sha256 — bir xil fayl 2 marta yuklanmaydi
  fileType     FileType
  branchId     Int?         // METRICS uchun majburiy, SALES bir filialli bo'lsa shunchaki
  periodStart  DateTime?    @db.Date
  periodEnd    DateTime?    @db.Date
  yearOverride Int?         // VISITS faylda yil bo'lmaganda admin tanlaydi
  templateVersion String?   // sotuv shabloni versiyasi (header signaturasidan: v1/v2/v3)
  rowCount     Int          @default(0)
  status       UploadStatus @default(SUCCESS)
  errorMessage String?
  uploadedById Int
  createdAt    DateTime     @default(now())

  uploadedBy User    @relation(fields: [uploadedById], references: [id])
  branch     Branch? @relation(fields: [branchId], references: [id])

  sales        CategorySales[]
  productSales ProductSales[]
  metrics      DailyMetrics[]
  visits       DailyVisits[]

  @@index([fileType, periodStart, periodEnd])
  @@index([uploadedById])
}

// Kunlik chek metrikalari — QO'LDA kiritiladi (sr.xlsx emas). Filial × sana.
// Chek soni va chekdagi o'rtacha tovar soni (Tashriflar bo'limi tabida).
model DailyReceiptMetric {
  id              Int      @id @default(autoincrement())
  branchId        Int
  date            DateTime @db.Date
  receiptCount    Int      @default(0) // kunlik chek soni
  itemsPerReceipt Decimal  @default(0) @db.Decimal(10, 3) // chekdagi o'rtacha tovar soni
  createdById     Int? // kim kiritdi (audit)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
}

// ─── Master baza: mahsulot (SKU) darajasidagi ma'lumot ───────────────────────
// Yangi sotuv shabloni (ShablonSotuv.xlsx) mahsulot darajasida keladi.
// Product = 1C mahsulot katalogi; ProductSales = SKU × filial × davr fakt jadval.

model Product {
  id         Int      @id @default(autoincrement())
  code       Int      @unique // 1C mahsulot kodi
  name       String
  categoryId Int? // tegishli kategoriya/subkategoriya (iyerarxiyadagi joyi)
  supplierId Int? // yetkazib beruvchi (POSTAVSHIK)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Joriy holat — har yuklashda denormalizatsiya qilinadi (OOS/zakaz so'rovi
  // ProductSales tarixini skanlamasligi uchun). Manba — eng so'nggi davr.
  currentStock   Decimal?  @db.Decimal(20, 3) // so'nggi davrdagi qoldiq (filiallar yig'indisi)
  currentSold    Decimal?  @db.Decimal(20, 3) // so'nggi davrdagi sotuv (dona)
  abcClass       String?   @db.Char(1) // ABC sinfi (standart 3 oylik oyna) — sotuv yuklashda yangilanadi
  xyzClass       String?   @db.Char(1) // XYZ sinfi (talab barqarorligi) — sotuv yuklashda yangilanadi
  leadTimeDays   Int? // zakazdan kelguncha kunlar — yetkazib beruvchi profilida kiritiladi
  archivedAt     DateTime? // no-aktiv (arxiv) — buyurtma/OOS/Stockday'dan chiqadi, tarix saqlanadi
  packSize       Int? // blok/yashik/pachkadagi dona soni — buyurtmada eslab qolinadi
  purchasePrice  Decimal? @db.Decimal(20, 2) // kelishilgan sotib olish narxi (dona) — zakazdan eslab qolinadi
  lastSalePeriod DateTime? @db.Date // so'nggi yuklangan davr (eskini bosib o'tmaslik uchun)

  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  sales        ProductSales[]
  nameMismatch ProductNameMismatch?
  orderItems   PurchaseOrderItem[]

  @@index([categoryId])
  @@index([supplierId])
}

// Kunlik sotuv faylidagi nom master nomidan farq qilsa — review uchun saqlanadi.
// Admin Moslanmagan → "Nom farqi" tabida: yangilaydi yoki master nomini saqlaydi.
model ProductNameMismatch {
  id             Int      @id @default(autoincrement())
  productId      Int      @unique
  fileName       String // sotuv faylidagi nom
  uploadedFileId Int?
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Yetkazib beruvchi (POSTAVSHIK) — sku.xlsx'dagi yetkazib beruvchi. Mahsulotga 1:N.
model Supplier {
  id            Int     @id @default(autoincrement())
  name          String  @unique // masalan "2-O'RIKZOR BOZOR"
  sortOrder     Int     @default(0)
  // ── Profil ──
  rating        Int? // 1..5 yulduz (menejer bahosi)
  ratingNote    String? // baho izohi
  phone         String?
  contactName   String? // mas'ul shaxs
  // Haftalik takrorlanuvchi zakaz qabul kunlari: 0=Yakshanba ... 6=Shanba (JS getUTCDay)
  orderWeekdays Int[]   @default([])

  products  Product[]
  orders    PurchaseOrder[]
  contracts SupplierContract[]
  sverkalar SverkaRecord[]
}

// Yetkazib beruvchi bilan shartnoma — hujjat fayli tashqi havola (Drive va h.k.) sifatida.
model SupplierContract {
  id         Int       @id @default(autoincrement())
  supplierId Int
  title      String // masalan "Yetkazib berish shartnomasi 2026"
  number     String? // shartnoma raqami
  signedAt   DateTime? @db.Date // imzolangan sana
  endDate    DateTime? @db.Date // amal qilish muddati
  amount     Decimal?  @db.Decimal(20, 2) // shartnoma summasi (bo'lsa)
  url        String? // hujjat havolasi (Google Drive va h.k.)
  note       String?
  createdAt  DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// Zakaz — yetkazib beruvchiga sotib olish buyurtmasi (kategoriya menejeri yaratadi).
model PurchaseOrder {
  id          Int         @id @default(autoincrement())
  supplierId  Int
  createdById Int // yaratgan foydalanuvchi (menejer/admin)
  status      OrderStatus @default(DRAFT)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sentAt      DateTime?
  receivedAt  DateTime?

  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([createdById])
  @@index([status])
}

model PurchaseOrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal @db.Decimal(20, 3)
  price     Decimal @db.Decimal(20, 2) // dona narxi
  packCount Int? // nechta blok/yashik buyurtma qilindi (ko'rinish uchun)
  packSize  Int? // o'sha paytdagi pachka hajmi (dona) — quantity = packCount × packSize

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId])
}

// Master sotuv fakti — SKU × filial × davr. Qayta yuklashda upsert (ustiga yoziladi).
model ProductSales {
  id             Int      @id @default(autoincrement())
  uploadedFileId Int
  productId      Int
  branchId       Int
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  stockQty       Decimal? @db.Decimal(20, 3) // Остаток (qoldiq dona)
  soldQty        Decimal? @db.Decimal(20, 3) // Количество (sotilgan dona)
  amount         Decimal  @db.Decimal(20, 2) // Продажи (savdo summasi)
  costAmount     Decimal? @db.Decimal(20, 2) // Себестоимость (tannarx)

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([branchId, periodStart, periodEnd])
  @@index([productId, periodStart, periodEnd])
  @@index([productId, branchId, periodEnd(sort: Desc)]) // OOS/Stockday "latest snapshot" DISTINCT ON tartibi
  @@index([uploadedFileId])
}

// Oylik sotuv rejasi — subkategoriya × filial × yil/oy
model SalesPlan {
  id         Int      @id @default(autoincrement())
  branchId   Int
  categoryId Int
  year       Int
  month      Int      // 1–12
  amount     Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId, year, month])
  @@index([branchId, year, month])
}

// Spisaniya (chiqim) kategoriya ko'prigi — bizbop kategoriya nomi → Iyerarxiya subkat.
// bizbop ALOHIDA bazada (cross-DB join yo'q) — shu sabab nom bo'yicha bog'laymiz.
// yozuvlar.kategoriya (matn) → botName → categoryId → bo'lim/kat/subkat rollup.
model SpisaniyaCategoryLink {
  id         Int      @id @default(autoincrement())
  botName    String   @unique // bizbop kategoriya nomi (yozuvlar.kategoriya bilan mos)
  categoryId Int // Iyerarxiya kategoriya/subkategoriya id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

// Sotuv bo'limi moliyasi — harajatlar (filialsiz, umumiy ro'yxat).
// Summa = miqdor × narx (serverda hisoblanadi).
model Expense {
  id          Int      @id @default(autoincrement())
  name        String // harajat nomi
  quantity    Decimal  @db.Decimal(20, 3) // miqdor
  unitPrice   Decimal  @db.Decimal(20, 2) // narx (bir birlik)
  amount      Decimal   @db.Decimal(20, 2) // summa = quantity × unitPrice
  spentAt     DateTime  @db.Date // harajat qilingan sana
  createdById Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime? // soft delete — moliyaviy yozuv butunlay o'chmaydi

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([spentAt])
  @@index([spentAt, deletedAt]) // finans sahifasi filtri: spentAt oralig'i + deletedAt IS NULL
  @@index([createdById])
}

// Marja rejasi — subkategoriya × filial (vaqtsiz, o'zgarganda yangilanadi)
model MarginPlan {
  id         Int      @id @default(autoincrement())
  branchId   Int
  categoryId Int
  marginPct  Decimal  @default(0) @db.Decimal(6, 2)
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([branchId, categoryId])
  @@index([branchId])
  @@index([categoryId])
}

// AI prognoz egri chizig'i — filial × bo'lim × oy uchun kunlik og'irlik (taqsimot shakli).
// Og'irliklar oy bo'yicha yig'indisi = 1. Kunlik prognoz = bo'lim oylik rejasi × weight.
// Shu sabab kunlik prognoz yig'indisi har doim aniq rejaga teng bo'ladi.
model ForecastCurve {
  id       Int      @id @default(autoincrement())
  branchId Int
  groupId  Int
  year     Int
  month    Int // 1–12
  date     DateTime @db.Date
  weight   Decimal  @db.Decimal(9, 8)

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  group  CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([branchId, groupId, year, month, date])
  @@index([branchId, year, month])
  @@index([date])
}

// Kunlik prognoz summasi — filial × oy × kun (barcha bo'limlar yig'indisi).
// Dashboard va Rejalar "Kunlik prognoz" tab shu jadvalni o'qiydi/tahrirlaydi.
// locked=true — admin qo'lda o'zgartirgan kun; qayta taqsimlashda o'zgarmaydi.
// Yig'indi (oy bo'yicha) = filial oylik reja summasiga teng (tahrirda saqlanadi).
model ForecastDay {
  id       Int      @id @default(autoincrement())
  branchId Int
  year     Int
  month    Int
  date     DateTime @db.Date
  amount   Decimal  @db.Decimal(18, 2)
  locked   Boolean  @default(false)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, year, month, date])
  @@index([date])
  @@index([branchId, year, month])
}

// Prognoz yaratish jurnali — filial × bo'lim × oy uchun AI izohi va meta.
model ForecastRun {
  id        Int      @id @default(autoincrement())
  branchId  Int
  groupId   Int
  year      Int
  month     Int
  model     String // ishlatilgan model (yoki "fallback")
  rationale String // AI ning qisqa izohi (nega shunday taqsimladi)
  createdAt DateTime @default(now())

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  group  CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([branchId, groupId, year, month])
  @@index([branchId, year, month])
}

// ─── Yetkazib beruvchi anketasi (supplier.oilagroup.uz) ──────────────────────────────
// Forma maydonlari sozlanuvchan — Tizim → Anketa bo'limida tahrirlanadi.
model AnketaField {
  id        Int      @id @default(autoincrement())
  section   String // bo'lim sarlavhasi (KOMPANIYA HAQIDA UMUMIY MA'LUMOT ...)
  label     String
  type      String   @default("text") // text | textarea | number | yesno | consent
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Yuborilgan anketalar — javoblar JSON ({ fieldId: qiymat })
model AnketaSubmission {
  id          Int      @id @default(autoincrement())
  companyName String // tezkor ro'yxat uchun (Kompaniya nomi javobidan)
  phone       String?
  answers     Json
  status      String   @default("NEW") // NEW | REVIEWED
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

// ─── Sverka — yetkazib beruvchi bilan solishtirish yozuvi (Telegram Mini App) ──
// Kiritish tartibi: sana → firma (Supplier'dan tanlanadi) → sklad → kontragent →
// dagavor → summa + nakladnoy rasmi (Telegram file_id, rasm-yukla sxemasi).
model SverkaRecord {
  id         Int      @id @default(autoincrement())
  sana       DateTime @db.Date
  supplierId Int? // firma — yetkazib beruvchilar bazasidan (o'chsa NULL, nom qoladi)
  firmaNomi  String // tanlash paytidagi nom (snapshot)
  sklad      String
  kontragent String
  dagavor    String
  summa      Decimal  @db.Decimal(20, 2)
  rasmFileId String // nakladnoy rasmi — Telegram file_id
  tgUserId   BigInt // kim kiritdi (Telegram ID)
  tgUserName String?
  createdAt  DateTime @default(now())

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([sana])
  @@index([supplierId])
  @@index([createdAt])
}

// Sverka botiga ruxsat berilgan xodimlar (alohida bot, alohida ro'yxat —
// ERP Sverka sahifasida SA/SUPPLYCHAIN boshqaradi).
model SverkaXodim {
  id        Int      @id @default(autoincrement())
  tgUserId  BigInt   @unique
  ism       String?
  createdAt DateTime @default(now())
}

// Umumiy kalit-qiymat sozlamalar (asosiy baza) — masalan SVERKA_GROUP_CHAT_ID
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
